  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "start:tunnel": "expo start --tunnel",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "npm run db:migrate --workspace=@bioos/server",
    "db:migrate:deploy": "npm run db:migrate:deploy --workspace=@bioos/server",
    "db:seed": "npm run db:seed --workspace=@bioos/server",
    "db:studio": "npm run db:studio --workspace=@bioos/server",
    "server:dev": "npm run dev --workspace=@bioos/server",
    "setup": "npm run db:up && sleep 3 && npm run db:migrate && npm run db:seed",
    "postinstall": "patch-package",
    "build:ios:preview": "eas build --platform ios --profile preview",
    "build:download:ios": "eas build:download --platform ios",
    "device:register": "eas device:create"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
