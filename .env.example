# PostgreSQL (used by server + Prisma)
DATABASE_URL="postgresql://bioos:bioos@localhost:5432/bioos?schema=public"

# API server
PORT=3001
API_URL="http://localhost:3001"

# Better Auth — generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3001"

# Expo mobile app — point at your API (local dev / simulator)
EXPO_PUBLIC_API_URL="http://localhost:3001"

# EAS preview builds read EXPO_PUBLIC_API_URL from eas.json (preview profile).
# Use a stable public URL (deployed API or ngrok) so physical devices can reach the server.

# AI — Groq is tried first, then OpenAI, then rules-based templates
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"

# Optional OpenAI fallback
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Optional web research for Dosify AI citations (trusted domains).
# Without this, AI still cites OpenFDA + PubMed (free, no key).
TAVILY_API_KEY=""

# Stripe Billing (Dosify Pro subscriptions)
# Create Products + recurring Prices in Stripe Dashboard, then paste IDs below.
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_MONTHLY=""
STRIPE_PRICE_YEARLY=""
# Web app origin(s) for Checkout success/cancel redirects (comma-separated)
WEB_APP_URL="http://localhost:8081"
