generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum IntakeMethod {
  ORAL
  TOPICAL
  INJECTION
  INHALATION
  OTHER
}

enum IntakeStatus {
  DRAFT
  LOGGED
  ANALYZED
}

enum RiskLevel {
  LOW
  MODERATE
  HIGH
}

enum NotificationType {
  INTERACTION_ALERT
  HYDRATION_REMINDER
  MEDICATION_REMINDER
  GOAL_SUCCESS
  GENERAL
  DOSE_MISSED
  REFILL_DUE
  LOW_STOCK
  FAMILY
  /// Above-average dose, frequent logging, or elevated analysis load
  DOSE_PATTERN
}

enum ConditionStatus {
  ACTIVE
  RESOLVED
  INACTIVE
}

enum AllergySeverity {
  MILD
  MODERATE
  SEVERE
  UNKNOWN
}

enum ConsentScope {
  TERMS_OF_SERVICE
  PRIVACY_POLICY
  HEALTH_DATA_PROCESSING
  WEARABLE_SYNC
  AI_ANALYSIS
}

enum ScheduleRecurrence {
  DAILY
  WEEKDAYS
  WEEKLY
  INTERVAL
}

enum DoseStatus {
  DUE
  TAKEN
  SKIPPED
  SNOOZED
  MISSED
}

enum InteractionCheckItemRole {
  PROPOSED
  CABINET
  RECENT_INTAKE
}

model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  name                String
  emailVerified       Boolean  @default(false)
  image               String?
  isPremium           Boolean  @default(false)
  onboardingCompleted Boolean  @default(false)
  stripeCustomerId    String?  @unique
  stripeSubscriptionId String? @unique
  stripePriceId       String?
  stripeSubscriptionStatus String?
  premiumExpiresAt    DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  healthProfile     HealthProfile?
  healthGoals       HealthGoal[]
  intakeLogs        IntakeLog[]
  interactions      Interaction[]
  recoverySnapshots RecoverySnapshot[]
  notifications     Notification[]
  wearableSnapshots WearableSnapshot[]
  sessions          Session[]
  accounts          Account[]
  conditions        Condition[]
  allergyRecords    Allergy[]
  consentRecords    ConsentRecord[]
  auditEvents       AuditEvent[]
  cabinetItems      CabinetItem[]
  medicationSchedules MedicationSchedule[]
  doseEvents        DoseEvent[]
  interactionChecks InteractionCheck[]
  emergencyContacts EmergencyContact[]
  symptomLogs       SymptomLog[]
  householdsOwned   Household[]           @relation("HouseholdOwner")
  householdMembers  HouseholdMember[]
  careGrantsGiven   CareGrant[]           @relation("CareGrantOwner")
  careGrantsReceived CareGrant[]          @relation("CareGrantCaregiver")
  healthReports     HealthReport[]
  aiChatMessages    AiChatMessage[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

model HealthProfile {
  id                String  @id @default(cuid())
  userId            String  @unique
  age               Int?
  weightKg          Float?
  heightCm          Float?
  gender            Gender?
  medicalConditions String?
  allergies         String?
  emergencyInfo     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model HealthGoal {
  id        String   @id @default(cuid())
  userId    String
  goal      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SubstanceCategory {
  id        String      @id @default(cuid())
  name      String      @unique
  slug      String      @unique
  icon      String?
  substances Substance[]
}

model Substance {
  id           String   @id @default(cuid())
  name         String
  description  String?
  categoryId   String
  defaultUnit  String   @default("mg")
  minDose      Float?
  maxDose      Float?
  isPopular    Boolean  @default(false)
  createdAt    DateTime @default(now())

  category     SubstanceCategory @relation(fields: [categoryId], references: [id])
  profile      SubstanceProfile?
  intakeLogs   IntakeLog[]
  interactionsA Interaction[] @relation("SubstanceA")
  interactionsB Interaction[] @relation("SubstanceB")
  cabinetItems          CabinetItem[]
  interactionCheckItems InteractionCheckItem[]
  products              Product[]
  productIngredients    ProductIngredient[]

  @@index([categoryId])
  @@index([name])
}

model SubstanceProfile {
  id                      String   @id @default(cuid())
  substanceId             String   @unique
  drugClass               String?
  halfLifeHours           Float?
  cognitiveImpact         Float    @default(0.3)
  cardiovascularImpact      Float    @default(0.2)
  gastrointestinalImpact  Float    @default(0.2)
  liverImpact             Float    @default(0.1)
  kidneyImpact            Float    @default(0.1)
  respiratoryImpact       Float    @default(0.1)
  typicalDurationMinHours Float?
  typicalDurationMaxHours Float?
  maxDailyDose            Float?

  substance Substance @relation(fields: [substanceId], references: [id], onDelete: Cascade)
}

model InteractionRule {
  id              String    @id @default(cuid())
  substanceA      String
  substanceB      String
  substanceAClass String?
  substanceBClass String?
  riskLevel       RiskLevel
  title           String
  description     String
  advice          String?
  source          String?

  @@index([substanceA, substanceB])
  @@index([substanceAClass, substanceBClass])
}

model IntakeLog {
  id          String       @id @default(cuid())
  userId      String
  substanceId String
  dose        Float
  unit        String
  takenAt     DateTime
  method      IntakeMethod @default(ORAL)
  purpose     String?
  status      IntakeStatus @default(LOGGED)
  /// When set, this intake was created from marking a scheduled dose taken.
  doseEventId String?      @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  substance Substance  @relation(fields: [substanceId], references: [id])
  doseEvent DoseEvent? @relation(fields: [doseEventId], references: [id], onDelete: SetNull)
  analysis  Analysis?

  @@index([userId, takenAt])
  @@index([substanceId])
}

model Analysis {
  id                    String   @id @default(cuid())
  intakeLogId           String   @unique
  overallScore          Int
  cognitiveScore        Int
  cardiovascularScore   Int
  gastrointestinalScore Int
  liverScore            Int      @default(0)
  kidneyScore           Int      @default(0)
  respiratoryScore      Int      @default(0)
  interactionRiskScore  Int
  durationMinHours      Float?
  durationMaxHours      Float?
  summary               String?
  recommendations       Json?
  warnings              Json?
  aiGenerated           Boolean  @default(false)
  engineVersion         String   @default("1.0.0")
  createdAt             DateTime @default(now())

  intakeLog IntakeLog @relation(fields: [intakeLogId], references: [id], onDelete: Cascade)
}

model Interaction {
  id           String    @id @default(cuid())
  userId       String
  substanceAId String
  substanceBId String
  riskLevel    RiskLevel
  title        String
  description  String
  advice       String?
  snoozedUntil DateTime?
  detectedAt   DateTime  @default(now())

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  substanceA Substance @relation("SubstanceA", fields: [substanceAId], references: [id])
  substanceB Substance @relation("SubstanceB", fields: [substanceBId], references: [id])

  @@index([userId])
}

model RecoverySnapshot {
  id                  String   @id @default(cuid())
  userId              String
  score               Int
  cognitivePct        Int
  cardiovascularPct   Int
  liverPct            Int
  kidneyPct           Int      @default(70)
  respiratoryPct      Int      @default(70)
  sleepPct            Int
  estimatedRecoveryAt DateTime?
  recordedAt          DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, recordedAt])
}

model WearableSnapshot {
  id               String   @id @default(cuid())
  userId           String
  source           String   @default("HEALTHKIT")
  heartRateAvg     Float?
  restingHeartRate Float?
  steps            Int?
  sleepHours       Float?
  activeEnergyKcal Float?
  recordedAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, recordedAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// ---------------------------------------------------------------------------
// Phase 0+1: safety foundations
// ---------------------------------------------------------------------------

model Condition {
  id        String          @id @default(cuid())
  userId    String
  name      String
  status    ConditionStatus @default(ACTIVE)
  onsetAt   DateTime?
  notes     String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model Allergy {
  id        String          @id @default(cuid())
  userId    String
  allergen  String
  reaction  String?
  severity  AllergySeverity @default(UNKNOWN)
  notes     String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ConsentRecord {
  id        String       @id @default(cuid())
  userId    String
  scope     ConsentScope
  version   String
  granted   Boolean
  grantedAt DateTime     @default(now())
  revokedAt DateTime?
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, scope])
}

model AuditEvent {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([entityType, entityId])
}

model EvidenceSource {
  id          String    @id @default(cuid())
  title       String
  url         String?
  publisher   String?
  publishedAt DateTime?
  retrievedAt DateTime?
  createdAt   DateTime  @default(now())

  citations EvidenceCitation[]
}

model EvidenceCitation {
  id         String   @id @default(cuid())
  sourceId   String
  entityType String
  entityId   String
  quote      String?
  createdAt  DateTime @default(now())

  source EvidenceSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId])
  @@index([entityType, entityId])
}

// ---------------------------------------------------------------------------
// Phase 0+1: Health Cabinet, medication schedules, dose events
// ---------------------------------------------------------------------------

model CabinetItem {
  id             String    @id @default(cuid())
  userId         String
  substanceId    String
  displayName    String?
  doseValue      Float?
  doseUnit       String?
  strengthValue  Float?
  strengthUnit   String?
  quantity       Float?
  expirationDate DateTime?
  refillDate     DateTime?
  prescriber     String?
  instructions   String?
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  substance Substance @relation(fields: [substanceId], references: [id])
  schedules  MedicationSchedule[]
  doseEvents DoseEvent[]

  @@index([userId, active])
  @@index([substanceId])
}

model MedicationSchedule {
  id            String             @id @default(cuid())
  userId        String
  cabinetItemId String
  timezone      String             @default("UTC")
  recurrence    ScheduleRecurrence
  // Local wall-clock times as ["HH:mm", ...] for DAILY/WEEKDAYS/WEEKLY.
  times         Json?
  intervalHours Int?
  // Days of week as [0..6] (0 = Sunday) for WEEKLY.
  daysOfWeek    Json?
  startDate     DateTime
  endDate       DateTime?
  instructions  String?
  active        Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  cabinetItem CabinetItem @relation(fields: [cabinetItemId], references: [id], onDelete: Cascade)
  doseEvents  DoseEvent[]

  @@index([userId, active])
  @@index([cabinetItemId])
}

model DoseEvent {
  id            String     @id @default(cuid())
  userId        String
  scheduleId    String?
  cabinetItemId String
  scheduledFor  DateTime
  status        DoseStatus @default(DUE)
  actedAt       DateTime?
  snoozedUntil  DateTime?
  note          String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedule    MedicationSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  cabinetItem CabinetItem         @relation(fields: [cabinetItemId], references: [id], onDelete: Cascade)
  intakeLog   IntakeLog?

  @@unique([scheduleId, scheduledFor])
  @@index([userId, scheduledFor])
  @@index([userId, status, scheduledFor])
  @@index([cabinetItemId])
}

// ---------------------------------------------------------------------------
// Phase 2: AI Interaction Predictor ("Check Before Taking")
// ---------------------------------------------------------------------------

model InteractionCheck {
  id                   String     @id @default(cuid())
  userId               String
  freeText             String?
  includeCabinet       Boolean    @default(true)
  includeRecentIntakes Boolean    @default(true)
  /// Snapshot of allergies, conditions, counts, and resolved substance ids.
  contextSnapshot      Json?
  riskScore            Int?
  highestRisk          RiskLevel?
  disclaimer           String
  aiRephrased          Boolean    @default(false)
  engineVersion        String     @default("1.0.0")
  createdAt            DateTime   @default(now())

  user     User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  items    InteractionCheckItem[]
  findings InteractionFinding[]

  @@index([userId, createdAt])
}

model InteractionCheckItem {
  id            String                   @id @default(cuid())
  checkId       String
  substanceId   String?
  substanceName String
  role          InteractionCheckItemRole
  createdAt     DateTime                 @default(now())

  check     InteractionCheck @relation(fields: [checkId], references: [id], onDelete: Cascade)
  substance Substance?       @relation(fields: [substanceId], references: [id], onDelete: SetNull)

  @@index([checkId])
  @@index([substanceId])
}

model InteractionFinding {
  id           String    @id @default(cuid())
  checkId      String
  substanceAId String?
  substanceBId String?
  riskLevel    RiskLevel
  title        String
  description  String
  advice       String?
  source       String?
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())

  check InteractionCheck @relation(fields: [checkId], references: [id], onDelete: Cascade)

  @@index([checkId])
}

// ---------------------------------------------------------------------------
// Phase 3: Product catalog + barcode lookup
// ---------------------------------------------------------------------------

model Product {
  id           String   @id @default(cuid())
  name         String
  brand        String?
  dosageForm   String?
  manufacturer String?
  description  String?
  substanceId  String?
  externalId   String?
  createdAt    DateTime @default(now())

  substance   Substance?          @relation(fields: [substanceId], references: [id], onDelete: SetNull)
  barcodes    ProductBarcode[]
  ingredients ProductIngredient[]

  @@index([name])
  @@index([substanceId])
  @@index([externalId])
}

model ProductBarcode {
  id        String   @id @default(cuid())
  productId String
  code      String   @unique
  symbology String   @default("UPC")
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductIngredient {
  id            String  @id @default(cuid())
  productId     String
  substanceId   String
  strengthValue Float?
  strengthUnit  String?

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  substance Substance @relation(fields: [substanceId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([substanceId])
  @@unique([productId, substanceId])
}

// ---------------------------------------------------------------------------
// Phase 4: Family, emergency, symptoms, and reports
// ---------------------------------------------------------------------------

enum HouseholdRole {
  OWNER
  CAREGIVER
  DEPENDENT
}

enum HouseholdInviteStatus {
  PENDING
  ACCEPTED
  REVOKED
}

enum CareGrantScope {
  EMERGENCY_VIEW
  REPORTS_VIEW
  FULL_READ
}

enum HealthReportKind {
  CABINET_CSV
  DOSES_CSV
  SYMPTOMS_CSV
  CLINICIAN_SUMMARY
}

model EmergencyContact {
  id           String   @id @default(cuid())
  userId       String
  name         String
  relationship String?
  phone        String?
  email        String?
  isPrimary    Boolean  @default(false)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isPrimary])
}

model SymptomLog {
  id          String   @id @default(cuid())
  userId      String
  symptom     String
  severity    Int?
  notes       String?
  occurredAt  DateTime @default(now())
  relatedMeds String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt])
}

model Household {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner   User              @relation("HouseholdOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members HouseholdMember[]
  grants  CareGrant[]

  @@index([ownerId])
}

model HouseholdMember {
  id           String                @id @default(cuid())
  householdId  String
  userId       String?
  inviteEmail  String?
  role         HouseholdRole         @default(CAREGIVER)
  status       HouseholdInviteStatus @default(PENDING)
  invitedAt    DateTime              @default(now())
  acceptedAt   DateTime?
  revokedAt    DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([householdId, status])
  @@index([userId])
  @@index([inviteEmail])
  @@unique([householdId, inviteEmail])
}

model CareGrant {
  id          String         @id @default(cuid())
  householdId String?
  ownerUserId String
  caregiverUserId String
  scope       CareGrantScope @default(EMERGENCY_VIEW)
  active      Boolean        @default(true)
  grantedAt   DateTime       @default(now())
  revokedAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  household Household? @relation(fields: [householdId], references: [id], onDelete: SetNull)
  owner     User       @relation("CareGrantOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  caregiver User       @relation("CareGrantCaregiver", fields: [caregiverUserId], references: [id], onDelete: Cascade)

  @@index([ownerUserId, active])
  @@index([caregiverUserId, active])
  @@unique([ownerUserId, caregiverUserId, scope])
}

model HealthReport {
  id          String          @id @default(cuid())
  userId      String
  kind        HealthReportKind
  title       String
  dateFrom    DateTime?
  dateTo      DateTime?
  /// Generated artifact (CSV text or JSON summary). Kept short for MVP.
  content     String
  provenance  Json?
  createdAt   DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

/// Persisted Dosify AI turns — used for free-tier daily question limits.
model AiChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, role, createdAt])
}
