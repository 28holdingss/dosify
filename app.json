{
  "expo": {
    "name": "Dosify",
    "slug": "dosify",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/dosify.png",
    "scheme": "dosify",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dhafee.dosify",
      "appleTeamId": "8P89V48Z7J",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "aps-environment": "production",
        "com.apple.security.application-groups": [
          "group.com.dhafee.dosify"
        ]
      }
    },
    "android": {
      "package": "com.dhafee.dosify",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/dosify.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/dosify.png"
    },
    "plugins": [
      "expo-router",
      [
        "react-native-health",
        {
          "healthSharePermission": "Dosify reads heart rate, sleep, steps, and activity from Apple Watch to improve recovery insights."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/dosifybg.jpeg",
          "resizeMode": "cover",
          "backgroundColor": "#3B9BE8",
          "enableFullScreenImage_legacy": true
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-secure-store",
      "expo-notifications",
      [
        "expo-camera",
        {
          "cameraPermission": "Dosify uses the camera to scan medicine and supplement barcodes.",
          "barcodeScannerEnabled": true
        }
      ],
      "@bacons/apple-targets"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "http://localhost:3001",
      "router": {},
      "eas": {
        "projectId": "38929c25-7772-4697-a84d-9f062b6b547d"
      }
    },
    "owner": "dhafee"
  }
}
