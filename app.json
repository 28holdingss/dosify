{
  "expo": {
    "name": "Dosify",
    "slug": "dosify",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/dosify.png",
    "scheme": "dosify",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dhafee.dosify",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.dhafee.dosify",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/dosify.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/dosify.png"
    },
    "plugins": [
      "expo-router",
      [
        "react-native-health",
        {
          "healthSharePermission": "Dosify reads heart rate, sleep, steps, and activity from Apple Watch to improve recovery insights.",
          "healthUpdatePermission": "Dosify may save health summaries to Apple Health."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/dosify.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-secure-store",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "http://localhost:3001",
      "router": {},
      "eas": {
        "projectId": "38929c25-7772-4697-a84d-9f062b6b547d"
      }
    },
    "owner": "dhafee"
  }
}
